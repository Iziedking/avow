# Avow agent backend secrets. Copy to deploy/.env on the VPS and fill in. Never commit the real one.

# The platform wallet that funds agent plumbing and signs admin actions (suiprivkey1...).
AVOW_KEY=suiprivkey1...

# Claude, the agent's brain. The user-facing plan runs on Sonnet, the proof trace on Haiku.
ANTHROPIC_API_KEY=sk-ant-...

# Walrus Memory (from memory.walrus.xyz). Without these, memory is a no-op (the agent still runs).
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=0x...

# Lock browser requests to your site in production.
AVOW_CORS_ORIGIN=https://avow.site

# Optional overrides (defaults are fine).
# AGENT_PORT=8787
# AVOW_AGENTS_FILE=/data/agents.json
# AVOW_LLM_MODEL=claude-sonnet-4-6
# AVOW_REASONING_MODEL=claude-haiku-4-5
