# Shared-VPS setup: do NOT run this as a standalone Caddy. Add this one block to the Caddy you
# already run (the arcrun Caddy), then reload it. Caddy provisions TLS for api.avow.site
# automatically, and reverse-proxies to the avow-agent container on the shared Docker network.
api.avow.site {
	reverse_proxy avow-agent:8787
}
