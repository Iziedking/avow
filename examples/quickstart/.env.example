# Copy to .env and fill in. Never commit your real key.

# Your Sui private key in Bech32 form (suiprivkey1...). Export one with:
#   sui keytool export --key-identity <your-address> --json
AVOW_KEY=

# Optional. The agent address the mandate authorizes. Defaults to your own address,
# which is fine when you are both the owner and the agent.
AVOW_AGENT_ADDRESS=

# Filled in by create-mandate, then read by the agent.
AVOW_MANDATE_ID=
AVOW_ACCESS_ID=

# Optional. Defaults to testnet and the published testnet package.
AVOW_NETWORK=testnet
# AVOW_PACKAGE_ID=
