{
  "name": "avow-cli",
  "version": "0.1.0",
  "description": "The Avow CLI: set a mandate, anchor an agent's actions as verifiable evidence, and verify any record, from the terminal.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "avow": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iziedking/avow.git",
    "directory": "packages/cli"
  },
  "keywords": ["sui", "walrus", "seal", "ai-agents", "verifiable", "cli"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit",
    "avow": "tsx src/cli.ts"
  },
  "dependencies": {
    "avow-sdk": "^0.1.0",
    "@mysten/sui": "2.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
