{
  "name": "avow-sdk",
  "version": "0.1.0",
  "description": "Anchor an AI agent's actions as private, verifiable evidence on Walrus and Seal, and verify any anchored record. The trust layer any money-moving agent on Sui can plug into.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iziedking/avow.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Iziedking/avow#readme",
  "bugs": "https://github.com/Iziedking/avow/issues",
  "keywords": [
    "sui",
    "walrus",
    "seal",
    "ai-agents",
    "verifiable",
    "trust-layer",
    "provenance",
    "agentic-payments"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/seal": "1.1.3",
    "@mysten/sui": "2.17.0",
    "@mysten/walrus": "1.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
